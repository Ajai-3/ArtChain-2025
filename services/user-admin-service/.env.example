# ============================================================
# USER ADMIN SERVICE - Environment Variables Example
# Copy this file to .env.local (local dev) or .env.docker (docker)
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4001                             # Port the user-admin-service listens on

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ── RabbitMQ ─────────────────────────────────────────────────
# cloudamqp.com credentials (same for local and docker)
RABBITMQ_URL=

# ── PostgreSQL ───────────────────────────────────────────────
# Local  → postgresql://postgres:password@localhost:5432/user_admin_db?sslmode=disable
# Docker → postgresql://postgres:password@postgres:5432/user_admin_db?sslmode=disable
# Cloud  → postgresql://user:password@host:port/user_admin_db?sslmode=require
#
# Note: Use 'sslmode=disable' for local/docker development if SSL is not configured.
# Use 'sslmode=require' for any cloud or production environment. (eg: Aiven, Heroku, etc.)
DATABASE_URL=

# ── API Gateway ──────────────────────────────────────────────
# Local  → http://localhost:4000
# Docker → http://api-gateway:4000
API_GATEWAY_URL=

# ── AWS / CloudFront ─────────────────────────────────────────
AWS_CDN_DOMAIN=                       # e.g. xxxxxx.cloudfront.net

# ── JWT Secrets ──────────────────────────────────────────────
JWT_ACCESS_SECRET=                    # Secret for signing access tokens
JWT_REFRESH_SECRET=                   # Secret for signing refresh tokens
JWT_EMAIL_VERIFICATION_SECRET=        # Secret for email verification tokens

# ── JWT Expiry ───────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m             # e.g. 5m, 15m, 1h
JWT_REFRESH_EXPIRES_IN=30d            # e.g. 7d, 30d
EMAIL_EXPIRES_IN=5m                   # Email verification token expiry

# ── Firebase (Google Auth) ───────────────────────────────────
FIREBASE_PROJECT_ID=                  # Firebase project ID
FIREBASE_CLIENT_EMAIL=                # Firebase service account email
FIREBASE_PRIVATE_KEY=                 # Firebase service account private key

