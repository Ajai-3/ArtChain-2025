# ============================================================
# ELASTIC SEARCH SERVICE - Environment Variables Example
# Copy this file to .env.local (local dev) or .env.docker (docker)
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4004                             # Port the elastic-search-service listens on

# ── Elasticsearch ────────────────────────────────────────────
# Local  → http://localhost:9200
# Docker → http://elasticsearch:9200
ELASTIC_URL=

# ── RabbitMQ ─────────────────────────────────────────────────
# Local  → amqp://localhost:5672
# Docker → amqp://host.docker.internal:5672
RABBITMQ_URL=

# ── AWS / CloudFront ─────────────────────────────────────────
AWS_CDN_DOMAIN=                       # e.g. xxxxxx.cloudfront.net
