# ============================================================
# WALLET SERVICE - Environment Variables Example
# Copy this file to .env.local (local dev) or .env.docker (docker)
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4003                             # Port the wallet-service listens on

# ── Client / Frontend ────────────────────────────────────────
CLIENT_URL=http://localhost:5173     # Frontend URL

# ── RabbitMQ ─────────────────────────────────────────────────
# cloudamqp.com credentials (same for local and docker)
RABBITMQ_URL=

# ── PostgreSQL ───────────────────────────────────────────────
# Local  → postgresql://postgres:password@localhost:5432/wallet_db
# Docker → postgresql://postgres:password@postgres:5432/wallet_db
DATABASE_URL=

# ── API Gateway ──────────────────────────────────────────────
# Local  → http://localhost:4000
# Docker → http://api-gateway:4000
API_GATEWAY_URL=

# ── Platform ─────────────────────────────────────────────────
PLATFORM_ADMIN_ID=                    # Platform admin wallet ID

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=                    # Stripe secret key (sk_test_... or sk_live_...)
STRIPE_WEBHOOK_SECRET=                # Stripe webhook signing secret (whsec_...)
