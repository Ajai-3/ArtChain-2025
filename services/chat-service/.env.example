# ============================================================
# CHAT SERVICE - Environment Variables Example
# Copy this file to .env.local (local dev) or .env.docker (docker)
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4007                             # Port the chat-service listens on

# ── MongoDB ──────────────────────────────────────────────────
# Use mongodb+srv URI for MongoDB Atlas, or mongodb:// for local MongoDB
MONGO_URI=

# ── Redis ────────────────────────────────────────────────────
# Use local Redis URL for development, Upstash Redis URL for production
REDIS_URL=

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── User Service ─────────────────────────────────────────────
# Local  → http://localhost:4001
# Docker → http://user-admin-service:4001
USER_SERVICE_URL=

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                    # Must match api-gateway JWT_ACCESS_SECRET

# ── AWS / CloudFront ─────────────────────────────────────────
AWS_CDN_DOMAIN=                       # e.g. xxxxxx.cloudfront.net
