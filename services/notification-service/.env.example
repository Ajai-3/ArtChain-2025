# ============================================================
# NOTIFICATION SERVICE - Environment Variables Example
# Copy this file to .env
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4005                             # Port the notification-service listens on

# ── MongoDB ──────────────────────────────────────────────────
# Local  → mongodb://localhost:27017/artchain-notifications
# Docker → mongodb://host.docker.internal:27017/artchain-notifications
MONGO_URL=

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── RabbitMQ ─────────────────────────────────────────────────
# cloudamqp.com credentials (same for local and docker)
RABBITMQ_URL=

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com             # SMTP host
EMAIL_PORT=587                        # SMTP port (587 for TLS, 465 for SSL)
EMAIL_USER=                           # SMTP login email
EMAIL_PASS=                           # SMTP password or app password
EMAIL_FROM_NAME=ArtChain              # Display name for sent emails
EMAIL_FROM_ADDRESS=                   # From address for sent emails
EMAIL_SECURE=false                    # true for port 465 (SSL), false for 587 (TLS)

# ── AWS (Email Templates) ────────────────────────────────────
EMAIL_TEMPLATE_BUCKET=                # S3 bucket name storing email templates

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                    # Must match api-gateway JWT_ACCESS_SECRET
