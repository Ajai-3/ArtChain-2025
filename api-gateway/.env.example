# ============================================================
# API GATEWAY - Environment Variables Example
# Copy this file to .env.local (local dev) or .env.docker (docker)
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4000                             # Port the api-gateway listens on

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ── Downstream Service URLs ──────────────────────────────────
# Local dev  → http://localhost:<port>
# Docker     → http://<container-name>:<port>
MAIN_SERVICE_URL=                     # user-admin-service URL
WALLET_SERVICE_URL=                   # wallet-service URL
ART_SERVICE_URL=                      # art-service URL
NOTIFICATION_URL=                     # notification-service URL
S3_SERVICE_URL=                       # s3-service URL
ELASTIC_SEARCH_SERVICE_URL=           # elastic-search-service URL
CHAT_SERVICE_URL=                     # chat-service URL

# ── JWT Secrets ──────────────────────────────────────────────
JWT_ACCESS_SECRET=                    # Secret for signing access tokens
JWT_REFRESH_SECRET=                   # Secret for signing refresh tokens


# ── JWT Expiry ───────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m             # e.g. 5m, 15m, 1h
JWT_REFRESH_EXPIRES_IN=30d            # e.g. 7d, 30d

