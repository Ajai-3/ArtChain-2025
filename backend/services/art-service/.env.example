# ============================================================
# ART SERVICE - Environment Variables Example
# Copy this file to .env.local (local dev) or .env.docker (docker)
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4002                             # Port the art-service listens on

# ── MongoDB ──────────────────────────────────────────────────
# Use mongo atlas URL for production, local MongoDB URL for development
MONGO_URL=

# ── RabbitMQ ─────────────────────────────────────────────────
# Use cloud RabbitMQ UR
RABBITMQ_URL=

# ── Redis ────────────────────────────────────────────────────
# Use local Redis URL for development, Upstash Redis URL for production
REDIS_URL=

# ── API Gateway ──────────────────────────────────────────────
# Local  → http://localhost:4000
# Docker → http://api-gateway:4000
API_GATEWAY_URL=

# ── AWS / CloudFront ─────────────────────────────────────────
AWS_CDN_DOMAIN=                       # e.g. xxxxxx.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=               # CloudFront key pair ID
CLOUDFRONT_PRIVATE_KEY=               # CloudFront private key (PEM)

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=                    # Must match api-gateway JWT_ACCESS_SECRET

# ── Platform ─────────────────────────────────────────────────
PLATFORM_ADMIN_ID=                    # Platform admin wallet ID

# ── Loki ─────────────────────────────────────────────────────
LOKI_HOST=                            # e.g. https://xxxxx.grafana.net
LOKI_USER=                            # e.g. 123xxx
LOKI_TOKEN=                           # e.g. grafana token

