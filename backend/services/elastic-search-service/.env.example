# ============================================================
# ELASTIC SEARCH SERVICE - Environment Variables Example
# Copy this file to .env
# and fill in your actual values. DO NOT commit real secrets.
# ============================================================

# App
NODE_ENV=development                  # development | production
PORT=4004                             # Port the elastic-search-service listens on

# ── Elasticsearch ────────────────────────────────────────────
# Local  → http://localhost:9200
ELASTIC_URL=

# ── RabbitMQ ─────────────────────────────────────────────────
# Use cloud RabbitMQ or local RabbitMQ. For local, use amqp://localhost:5672
RABBITMQ_URL="amqps://nxmrliaz:xbXKady_3olRd8zcu-U5Dl6gynJ5qXYy@fuji.lmq.cloudamqp.com/nxmrliaz"

# ── AWS / CloudFront ─────────────────────────────────────────
AWS_CDN_DOMAIN=                       # e.g. xxxxxx.cloudfront.net

# ── Loki ─────────────────────────────────────────────────────
LOKI_HOST=                            # e.g. https://xxxxx.grafana.net
LOKI_USER=                            # e.g. 123xxx
LOKI_TOKEN=                           # e.g. grafana token

